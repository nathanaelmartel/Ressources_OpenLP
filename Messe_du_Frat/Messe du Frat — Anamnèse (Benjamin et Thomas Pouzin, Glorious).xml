    <titles>
      <title>Messe du Frat — Anamnèse</title>
    </titles>
    <authors>
      <author>Benjamin et Thomas Pouzin</author>
      <author>Glorious</author>
    </authors>
  </properties>
  <lyrics>
    <verse name="v1">
      <lines>Gloire à toi qui étais mort,<br/>Gloire à toi qui es vivant.<br/>Notre Sauveur et notre Dieu,<br/>viens, Seigneur Jésus !</lines>
    </verse>
  </lyrics>
