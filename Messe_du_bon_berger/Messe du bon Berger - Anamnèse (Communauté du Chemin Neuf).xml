    <titles>
      <title>Messe du bon Berger - Anamnèse</title>
    </titles>
    <authors>
      <author>Communauté du Chemin Neuf</author>
    </authors>
  </properties>
  <lyrics>
    <verse name="v1">
      <lines>Gloire à Toi qui étais mort,<br/>Gloire à Toi qui es vivant,<br/><p style="page-break-after: always;"/><br/>Notre sauveur et notre Dieu,<br/>Viens Seigneur Jésus, <br/>viens Seigneur Jésus, <br/>viens Seigneur Jésus</lines>
    </verse>
  </lyrics>
